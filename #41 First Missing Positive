int compare(const void *a,const void *b)
{
    int x= *(const int*)a;
    int y= *(const int*)b;

    if(x<y)return -1;
    if(x>y)return 1;
    return 0;
}

int firstMissingPositive(int* nums, int numsSize) {

   qsort(nums,numsSize,sizeof(int),compare);
    int res=1;
    for(int i=0;i<numsSize;i++)
    {
        if(nums[i]<res)
        {
           continue;
        }

        if(nums[i]==res)
        {
            res++;
        }
        else
        {
            return res;
        }
    }
    return res;

    
}
