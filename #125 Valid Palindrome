bool isPalindrome(char* s) {

    int d=strlen(s);
    int k=0;
    char res[99999];
    for(int i=0;s[i]!='\0';i++)
    {
        if((s[i]>=65 && s[i]<=90) || (s[i]>=97 && s[i]<=122) || (s[i]>=48 && s[i]<=57))
        {
            if (s[i] >= 'A' && s[i] <= 'Z')
                res[k++] = s[i] + 32;
            else
                res[k++] = s[i];
        }
    }

    for(int i=0,j=k-1;i<j;i++,j--)
    {
        if(res[i]!=res[j])
        {
            return false;
        }
    }
    return true;
    
}
