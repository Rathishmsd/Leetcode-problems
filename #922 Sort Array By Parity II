int* sortArrayByParityII(int* nums, int numsSize, int* returnSize) {

    int *res=malloc(numsSize*sizeof(int));
    int even=0,odd=1;
    for(int i=0;i<numsSize;i++)
    {
       if(nums[i]%2==0)
       {
        res[even]=nums[i];
        even = even+2;
       }
       else
       {
         res[odd]=nums[i];
         odd =odd+2;
       }
       
    }
    *returnSize=numsSize;
    return res;
    
}
