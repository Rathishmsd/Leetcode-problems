struct ListNode* mergeInBetween(struct ListNode* list1, int a, int b, struct ListNode* list2){

    struct ListNode*front=list1;
    struct ListNode*back=list1;

    for(int i=0;i<a-1;i++)
    {
        front=front->next;
    }
    back=front;
    for(int i=a;i<=b+1;i++)
    {
        back=back->next;
    }

    front->next=list2;
    while(list2->next!=NULL)
    {
        list2=list2->next;
    }
    list2->next=back;

    return list1;

}
