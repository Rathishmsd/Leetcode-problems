char* reverseStr(char* s, int k) {
    
    int d=strlen(s);

    for(int t=0;t<d;t = t+ 2*k)
    {
        int i=t;
        int j=t+k-1;
        if(j>=d)
        {
            j=d-1;
        }
        while(i<j)
        {
           char temp=s[i];
           s[i]=s[j];
           s[j]=temp;
           i++;
           j--;
        }
    }
    return s;
}
